# Application
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=25

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.2

# AWS / S3 (explicit creds for LocalStack; omit on EC2 with instance role)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_EXTERNAL_URL=                              # Public URL for presigned links (set in docker-compose for local dev)
S3_BUCKET_UPLOADS=resume-normalizer-uploads
S3_BUCKET_GENERATED=resume-normalizer-generated
S3_PRESIGNED_URL_EXPIRY=3600

# Database
DATABASE_URL=sqlite:///./api_keys.db

# Auth
ADMIN_API_KEY=admin-change-me-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# OCR
OCR_MIN_TEXT_LENGTH=50
TESSERACT_CMD=tesseract
