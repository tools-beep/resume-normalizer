# Application
APP_ENV=production
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=25

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.2

# AWS S3 (credentials come from EC2 instance role — no keys needed)
AWS_REGION=ap-southeast-1
S3_BUCKET_UPLOADS=your-app-uploads
S3_BUCKET_GENERATED=your-app-generated
S3_PRESIGNED_URL_EXPIRY=3600

# Database (SQLite on persistent volume)
DATABASE_URL=sqlite:////app/data/api_keys.db

# Auth
ADMIN_API_KEY=change-me-to-a-long-random-string

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
